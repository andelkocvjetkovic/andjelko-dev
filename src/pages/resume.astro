---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import EducationEntry from '../components/resume/EducationEntry.astro';
import ExperienceEntry from '../components/resume/ExperienceEntry.astro';
import ProjectEntry from '../components/resume/ProjectEntry.astro';
import ResumeHeader from '../components/resume/ResumeHeader.astro';
import Section from '../components/resume/Section.astro';
import { resume } from '../data/resume';

const skillGroups = [
  resume.skills.primary,
  ...resume.skills.alsoShipping.slice(0, 1),
  resume.skills.frontendEngineering,
  resume.skills.uiSystems,
  resume.skills.dataMaps,
  resume.skills.testing,
  resume.skills.cms,
  ...resume.skills.other,
  ...resume.skills.alsoShipping.slice(1),
  resume.skills.aiWorkflow,
];

const achievementHtml = [
  "Rendered 32,000+ map locations smoothly through viewport virtualization on <strong>Kam třídit</strong> (Czechia's nationwide recycling app), shipped across web, iOS, and Android.",
  'Achieved Lighthouse 97 on desktop (FCP 0.3s, LCP 1.1s, CLS 0) on <strong>BH-Passport</strong> by rebuilding a legacy WordPress site as a Next.js + Sanity application.',
  "Built a multi-product platform for Eko-kom (Czechia's national packaging recovery organization) — two consumer apps sharing a monorepo, design system, and CMS infrastructure.",
  'Shipped <strong>ScrumGlide</strong> end-to-end as solo frontend — multi-role ticketing, sprint planning, real-time socket sync, and analytics including burndown charts and epic timelines.',
] as const;
---

<Base title={`${resume.name} — Resume`}>
  <main class="container" aria-label={`${resume.name} resume`}>
    <ResumeHeader name={resume.name} title={resume.title} location={resume.contact.location} />

    <div class="contact-bar">
      <a href="/resume/print?print=1" class="pdf-btn" aria-label="Download PDF">
        <svg
          width="11"
          height="11"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 1v7M3.5 5.5L6 8l2.5-2.5M2 10h8"></path>
        </svg>
        Download PDF
      </a>
    </div>

    <div class="contact-row">
      <div class="contact-item">
        <Icon name="lucide:mail" class="contact-icon" aria-hidden="true" />
        <a href={`mailto:${resume.contact.email}`}>{resume.contact.email}</a>
      </div>
      <div class="contact-item">
        <Icon name="lucide:github" class="contact-icon" aria-hidden="true" />
        <a href={resume.contact.github} target="_blank" rel="noopener">github.com/andelkocvjetkovic</a>
      </div>
      <div class="contact-item">
        <Icon name="lucide:linkedin" class="contact-icon" aria-hidden="true" />
        <a href={resume.contact.linkedin} target="_blank" rel="noopener">linkedin.com/in/andjelkocvjetkovic</a>
      </div>
    </div>

    <Section title="Summary">
      <p class="summary-text">{resume.summary}</p>
    </Section>

    <Section title="Selected Achievements">
      <ul class="achievement-list">
        {achievementHtml.map((achievement) => <li class="achievement-item"><span set:html={achievement} /></li>)}
      </ul>
    </Section>

    <Section title="Core Skills">
      <div class="skills-table">
        {
          skillGroups.map((group) => (
            <div class="skill-row">
              <span class="skill-label">{group.label}</span>
              <span class="skill-values">{group.items.join(' · ')}</span>
            </div>
          ))
        }
      </div>
    </Section>

    <Section title="Experience">
      {resume.experience.map((entry) => <ExperienceEntry entry={entry} />)}
    </Section>

    <Section title="Selected Projects">
      {resume.projects.map((project) => <ProjectEntry project={project} />)}
    </Section>

    <Section title="Education">
      {resume.education.map((entry) => <EducationEntry entry={entry} />)}
    </Section>

    <footer class="resume-footer">
      <p class="footer-text">© 2026 · {resume.name}</p>
    </footer>
  </main>
</Base>

<style>
  :global(:root) {
    --section-gap: 52px;
  }

  :global(html) {
    background: var(--bg);
    font-size: 15px;
  }

  :global(body) {
    background: var(--bg);
    padding: 64px 24px 80px;
  }

  .container {
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }

  .contact-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
  }

  .pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 6px 14px;
    border-radius: 2px;
    cursor: pointer;
    background: transparent;
    transition:
      background 0.15s,
      color 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .pdf-btn:hover {
    background: var(--gold);
    color: var(--fg);
    text-decoration: none;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--section-gap);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--fg);
    padding: 0 16px 0 0;
  }

  .contact-item:not(:last-child)::after {
    content: '';
    display: inline-block;
    width: 1px;
    height: 12px;
    background: var(--border);
    margin-left: 16px;
    vertical-align: middle;
  }

  .contact-icon {
    width: 13px;
    height: 13px;
    color: var(--fg-muted);
    flex-shrink: 0;
  }

  .summary-text {
    font-size: 14px;
    line-height: 1.75;
    color: var(--fg);
    max-width: 640px;
  }

  .achievement-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .achievement-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--fg);
  }

  .achievement-item::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    background: var(--gold);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .achievement-item span {
    display: block;
  }

  .achievement-item strong {
    font-weight: 600;
  }

  .skills-table {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .skill-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    align-items: baseline;
  }

  .skill-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-top: 1px;
  }

  .skill-values {
    font-size: 13.5px;
    color: var(--fg);
    line-height: 1.5;
  }

  .resume-footer {
    border-top: 1px solid var(--border);
    padding-top: 20px;
    margin-top: 0;
    text-align: center;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }

  @media print {
    @page {
      size: A4 portrait;
      margin: 1.4cm 1.6cm;
    }

    :global(html),
    :global(body) {
      background: #fff !important;
      padding: 0;
      font-size: 13px;
    }

    :global(:root) {
      --section-gap: 36px;
      --bg: #fff;
    }

    .pdf-btn,
    .contact-bar {
      display: none !important;
    }

    :global(.section),
    :global(.project-entry),
    :global(.entry),
    .contact-row {
      break-inside: avoid;
    }

    .achievement-item::before,
    .pdf-btn,
    :global(.project-link) {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }

  @media (max-width: 600px) {
    .skill-row {
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .contact-item:not(:last-child)::after {
      display: none;
    }

    .contact-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
