---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import EducationEntry from '../components/resume/EducationEntry.astro';
import ExperienceEntry from '../components/resume/ExperienceEntry.astro';
import ProjectEntry from '../components/resume/ProjectEntry.astro';
import ResumeHeader from '../components/resume/ResumeHeader.astro';
import Section from '../components/resume/Section.astro';
import { resume } from '../data/resume';

const isPrintMode = Astro.url.searchParams.get('print') === '1';

const skillGroups = [
  resume.skills.primary,
  ...resume.skills.alsoShipping.slice(0, 1),
  resume.skills.frontendEngineering,
  resume.skills.uiSystems,
  resume.skills.dataMaps,
  resume.skills.testing,
  resume.skills.cms,
  ...resume.skills.other,
  ...resume.skills.alsoShipping.slice(1),
  resume.skills.aiWorkflow,
];

---

<Base title={`${resume.name} — Resume`} bodyClass={isPrintMode ? 'resume-print' : undefined}>
  <main class="container" aria-label={`${resume.name} resume`}>
    <ResumeHeader name={resume.name} title={resume.title} location={resume.contact.location} />

    <div class="contact-bar">
      <a href="/andjelko.cvjetkovic-resume.pdf" class="pdf-btn" aria-label="Download PDF">
        <svg
          width="11"
          height="11"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 1v7M3.5 5.5L6 8l2.5-2.5M2 10h8"></path>
        </svg>
        Download PDF
      </a>
    </div>

    <div class="contact-row">
      <div class="contact-item">
        <Icon name="lucide:mail" class="contact-icon" aria-hidden="true" />
        <a href={`mailto:${resume.contact.email}`}>{resume.contact.email}</a>
      </div>
      <div class="contact-item">
        <Icon name="lucide:github" class="contact-icon" aria-hidden="true" />
        <a href={resume.contact.github} target="_blank" rel="noopener">github.com/andelkocvjetkovic</a>
      </div>
      <div class="contact-item">
        <Icon name="lucide:linkedin" class="contact-icon" aria-hidden="true" />
        <a href={resume.contact.linkedin} target="_blank" rel="noopener">linkedin.com/in/andjelkocvjekovic</a>
      </div>
    </div>

    <Section title="Summary">
      <p class="summary-text">{resume.summary}</p>
    </Section>

    <Section title="Selected Achievements">
      <ul class="achievement-list">
        {resume.achievements.map((achievement) => <li class="achievement-item"><span>{achievement}</span></li>)}
      </ul>
    </Section>

    <Section title="Core Skills">
      <div class="skills-table">
        {
          skillGroups.map((group) => (
            <div class="skill-row">
              <span class="skill-label">{group.label}</span>
              <span class="skill-values">{group.items.join(' · ')}</span>
            </div>
          ))
        }
      </div>
    </Section>

    <Section title="Experience">
      {resume.experience.map((entry) => <ExperienceEntry entry={entry} />)}
    </Section>

    <Section title="Selected Projects">
      {resume.projects.map((project) => <ProjectEntry project={project} />)}
    </Section>

    <Section title="Education">
      {resume.education.map((entry) => <EducationEntry entry={entry} />)}
    </Section>

    <footer class="resume-footer">
      <p class="footer-text">© 2026 · {resume.name}</p>
    </footer>
  </main>
</Base>

<style>
  :global(:root) {
    --section-gap: 52px;
  }

  :global(html) {
    background: var(--bg);
    font-size: 15px;
  }

  :global(body) {
    background: var(--bg);
    padding: 64px 24px 80px;
  }

  .container {
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }

  .contact-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
  }

  .pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 6px 14px;
    border-radius: 2px;
    cursor: pointer;
    background: transparent;
    transition:
      background 0.15s,
      color 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .pdf-btn:hover {
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--section-gap);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--fg);
    padding: 0 16px 0 0;
  }

  .contact-item:not(:last-child)::after {
    content: '';
    display: inline-block;
    width: 1px;
    height: 12px;
    background: var(--border);
    margin-left: 16px;
    vertical-align: middle;
  }

  .contact-icon {
    width: 13px;
    height: 13px;
    color: var(--fg-muted);
    flex-shrink: 0;
  }

  .summary-text {
    font-size: 14px;
    line-height: 1.75;
    color: var(--fg);
    max-width: 640px;
  }

  .achievement-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .achievement-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--fg);
    break-inside: avoid;
    page-break-inside: avoid;
  }

  .achievement-item::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .achievement-item span {
    display: block;
  }

  .achievement-item strong {
    font-weight: 600;
  }

  .skills-table {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .skill-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    align-items: baseline;
  }

  .skill-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-top: 1px;
  }

  .skill-values {
    font-size: 13.5px;
    color: var(--fg);
    line-height: 1.5;
  }

  .resume-footer {
    border-top: 1px solid var(--border);
    padding-top: 20px;
    margin-top: 0;
    text-align: center;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }

  :global(body.resume-print) {
    --bg: #fff;
    --section-gap: 36px;
    background: #fff;
    padding: 0;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  :global(body.resume-print) .contact-bar {
    display: none;
  }

  :global(body.resume-print) .container {
    max-width: none;
  }

  :global(body.resume-print .resume-name),
  :global(body.resume-print p),
  :global(body.resume-print li),
  :global(body.resume-print li span),
  :global(body.resume-print .summary-text),
  :global(body.resume-print .achievement-item),
  :global(body.resume-print .skill-values),
  :global(body.resume-print .exp-company),
  :global(body.resume-print .exp-intro),
  :global(body.resume-print .bullet-item),
  :global(body.resume-print .project-name),
  :global(body.resume-print .project-intro),
  :global(body.resume-print .project-stack),
  :global(body.resume-print .edu-degree),
  :global(body.resume-print .edu-institution) {
    letter-spacing: normal;
  }

  :global(body.resume-print) :global(.project-entry),
  :global(body.resume-print) :global(.entry),
  :global(body.resume-print) .achievement-item,
  :global(body.resume-print) .contact-row {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  :global(body.resume-print) :global(.section-heading) {
    break-after: avoid;
    page-break-after: avoid;
  }

  @media print {
    :global(html),
    :global(body) {
      background: #fff !important;
      padding: 0;
      font-size: 13px;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    :global(:root) {
      --section-gap: 36px;
      --bg: #fff;
    }

    :global(.resume-name),
    :global(p),
    :global(li),
    :global(li span),
    .summary-text,
    .achievement-item,
    .skill-values,
    :global(.exp-company),
    :global(.exp-intro),
    :global(.bullet-item),
    :global(.project-name),
    :global(.project-intro),
    :global(.project-stack),
    :global(.edu-degree),
    :global(.edu-institution) {
      letter-spacing: normal;
    }

    .pdf-btn,
    .contact-bar {
      display: none !important;
    }

    :global(.project-entry),
    :global(.entry),
    .achievement-item,
    .contact-row {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    :global(.section-heading) {
      break-after: avoid;
      page-break-after: avoid;
    }

    .achievement-item::before,
    .pdf-btn,
    :global(.project-link) {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }

  @media (max-width: 600px) {
    .skill-row {
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .contact-item:not(:last-child)::after {
      display: none;
    }

    .contact-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
