---
import type { EducationEntry as EducationEntryType } from '../../data/resume';

interface Props {
  entry: EducationEntryType;
}

const { entry } = Astro.props;
---

<article class="education">
  <p class="edu-degree">{entry.degree}</p>
  <p class="edu-institution">{entry.school}</p>
  <p class="edu-dates">{entry.dates} ({entry.status})</p>
</article>

<style>
  .education {
    break-inside: avoid;
  }

  .edu-degree {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 4px;
  }

  .edu-institution {
    font-size: 13.5px;
    color: var(--fg);
    margin-bottom: 4px;
    line-height: 1.5;
  }

  .edu-dates {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
  }
</style>
