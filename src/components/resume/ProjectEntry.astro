---
import type { ProjectEntry as ProjectEntryType } from '../../data/resume';

interface Props {
  project: ProjectEntryType;
}

const { project } = Astro.props;
const links = project.links ?? (project.link ? [project.link] : []);
const hasSubSections = 'subSections' in project.sections;
---

<article class="project-entry">
  <div class="project-header-line">
    <span class="project-name">{project.name}</span>
    {
      links.map((link, index) => (
        <>
          <span class="project-link-sep">{index === 0 ? '—' : '·'}</span>
          <a href={link.href} class="project-link" target="_blank" rel="noopener">
            {link.label}
          </a>
        </>
      ))
    }
  </div>
  <p class="project-subtitle">{project.subtitle}</p>
  {project.intro && <p class="project-intro">{project.intro}</p>}

  {
    hasSubSections ? (
      <>
        {project.sections.subSections.map((section) => (
          <div class="sub-section">
            <p class="sub-section-label">{section.title}</p>
            <ul class="bullet-list">
              {section.bullets.map((bullet) => <li class="bullet-item">{bullet}</li>)}
            </ul>
          </div>
        ))}
      </>
    ) : (
      <ul class="bullet-list">
        {project.sections.bullets.map((bullet) => <li class="bullet-item">{bullet}</li>)}
      </ul>
    )
  }

  <p class="project-stack">Stack: {project.stack.join(', ')}</p>
</article>

<style>
  .project-entry {
    margin-bottom: 32px;
    break-inside: avoid;
  }

  .project-entry:last-child {
    margin-bottom: 0;
  }

  .project-header-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 3px;
  }

  .project-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gold);
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .project-link:hover {
    text-decoration-color: var(--gold);
  }

  .project-link-sep {
    color: var(--fg-muted);
    font-size: 13px;
  }

  .project-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    font-style: italic;
    color: var(--fg-muted);
    margin-bottom: 12px;
  }

  .project-intro {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--fg);
    margin-bottom: 12px;
    max-width: 640px;
  }

  .bullet-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bullet-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 13px;
    line-height: 1.65;
    color: var(--fg);
  }

  .bullet-item::before {
    content: '–';
    color: var(--fg-muted);
    flex-shrink: 0;
  }

  .project-stack {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-muted);
    margin-top: 10px;
    letter-spacing: 0.02em;
  }

  .sub-section {
    margin-top: 16px;
  }

  .sub-section-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 8px;
  }
</style>
