---
interface Props {
  name: string;
  title: string;
  location: string;
}

const { name, title, location } = Astro.props;
---

<header class="resume-header">
  <div class="header-left">
    <h1 class="resume-name">{name}</h1>
    <p class="resume-title">{title} · {location} (Remote)</p>
  </div>
  <div class="header-right">
    <div class="avatar-placeholder" aria-label="Headshot">
      <img src="/headshot.jpg" alt="" />
    </div>
  </div>
</header>

<style>
  .resume-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .header-left {
    flex: 1;
  }

  .header-right {
    flex-shrink: 0;
  }

  .resume-name {
    font-size: 38px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--fg);
    margin-bottom: 8px;
  }

  .resume-title {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    letter-spacing: 0.03em;
  }

  .avatar-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--border);
    flex: 0 0 auto;
    overflow: hidden;
  }

  .avatar-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 28%;
  }

  @media (max-width: 600px) {
    .resume-header {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
</style>
