---
import type { ExperienceEntry as ExperienceEntryType } from '../../data/resume';

interface Props {
  entry: ExperienceEntryType;
}

const { entry } = Astro.props;
---

<article class="entry">
  <div class="exp-header">
    <p class="exp-company">{entry.company} — {entry.role}</p>
    <p class="exp-meta">{entry.dates} · {entry.location}</p>
  </div>
  {entry.description && <p class="exp-intro">{entry.description}</p>}
  <ul class="bullet-list">
    {entry.bullets.map((bullet) => <li class="bullet-item">{bullet}</li>)}
  </ul>
</article>

<style>
  .entry {
    break-inside: avoid;
    margin-bottom: 0;
  }

  .exp-header {
    margin-bottom: 8px;
  }

  .exp-company {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 3px;
  }

  .exp-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  .exp-intro {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--fg);
    margin-bottom: 12px;
    max-width: 640px;
  }

  .bullet-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bullet-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 13px;
    line-height: 1.65;
    color: var(--fg);
  }

  .bullet-item::before {
    content: '–';
    color: var(--fg-muted);
    flex-shrink: 0;
  }
</style>
