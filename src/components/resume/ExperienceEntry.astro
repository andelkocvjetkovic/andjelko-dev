---
import type { ExperienceEntry as ExperienceEntryType } from '../../data/resume';

interface Props {
  entry: ExperienceEntryType;
}

const { entry } = Astro.props;
---

<article class="entry">
  <div class="entry-head">
    <div>
      <h3>{entry.company}</h3>
      <p class="role">{entry.role}</p>
    </div>
    <p class="dates">{entry.dates}</p>
  </div>
  {entry.description && <p class="description">{entry.description}</p>}
  <ul>
    {entry.bullets.map((bullet) => <li>{bullet}</li>)}
  </ul>
</article>

<style>
  .entry {
    break-inside: avoid;
  }

  .entry-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: baseline;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    margin-bottom: 10px;
  }

  h3 {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .role,
  .dates {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .description {
    font-size: 12px;
    color: var(--fg-muted);
    margin-bottom: 10px;
  }

  ul {
    padding-left: 18px;
  }

  li {
    font-size: 12px;
    line-height: 1.65;
    color: var(--fg);
    margin-bottom: 5px;
  }

  li::marker {
    color: var(--gold);
  }

  @media (max-width: 640px) {
    .entry-head {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
