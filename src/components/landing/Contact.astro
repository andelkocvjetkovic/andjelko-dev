---
import { resume } from '../../data/resume';
---

<section id="contact">
  <p class="section-label">Contact</p>
  <p class="contact-main">
    Get in touch &mdash; <a href={`mailto:${resume.contact.email}`} class="email-link">{resume.contact.email}</a>
  </p>
  <div class="contact-links">
    <a href={resume.contact.github} class="contact-link">GitHub</a>
    <a href={resume.contact.linkedin} class="contact-link">LinkedIn</a>
    <a href="/andjelko.cvjetkovic-resume.pdf" class="contact-link">Resume (PDF)</a>
  </div>
</section>

<style>
  #contact {
    margin-bottom: var(--section-gap);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-main {
    font-size: 18px;
    font-weight: 500;
    margin-top: 32px;
    margin-bottom: 20px;
  }

  .email-link {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }

  .email-link:hover {
    text-decoration-color: var(--accent);
  }

  .contact-links {
    display: flex;
    gap: 24px;
  }

  .contact-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .contact-link:hover {
    color: var(--fg);
  }
</style>
