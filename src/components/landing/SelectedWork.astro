---
import ProjectRow from './ProjectRow.astro';

const projects = [
  {
    name: 'Kam třídit',
    description: "Czechia's nationwide recycling locator · Web, iOS, Android",
    stack: ['REACT', 'TYPESCRIPT', 'MAPLIBRE', 'TAILWIND'],
    href: 'https://kamtridit.cz',
  },
  {
    name: 'Čistou přírodou',
    description: 'Public nature-trails platform · Czechia',
    stack: ['REACT', 'TYPESCRIPT', 'MAPLIBRE', 'TAILWIND'],
    href: 'https://prirodou.samosebou.cz',
  },
  {
    name: 'BH-Passport',
    description: 'Travel agency platform · Bosnian market',
    stack: ['NEXT.JS', 'SANITY', 'TYPESCRIPT'],
    href: 'https://bhpassport.ba',
  },
  {
    name: 'TableTap',
    description: 'Codepool in-house product · QR-based ordering for restaurants',
    stack: ['SVELTE', 'ASTRO', 'TYPESCRIPT'],
    href: 'https://www.table-tap.app/',
  },
] as const;
---

<section id="work">
  <p class="section-label">Selected work</p>
  <ul class="work-list">
    {
      projects.map((project) => (
        <ProjectRow
          name={project.name}
          description={project.description}
          stack={project.stack}
          href={project.href}
        />
      ))
    }
  </ul>
</section>

<style>
  #work {
    margin-bottom: var(--section-gap);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .work-list {
    list-style: none;
    margin-top: 32px;
  }
</style>
