---
import ProjectRow from './ProjectRow.astro';

const projects = [
  {
    name: 'Kam třídit',
    description:
      "Czechia's nationwide recycling locator for EKO-KOM, the national packaging recycling authority. 33k+ locations kept fast with marker clustering and list virtualization, 200+ community contributors, Mapy.com autocomplete and turn-by-turn navigation to containers · Web, iOS, Android",
    stack: ['REACT', 'TYPESCRIPT', 'MAPLIBRE', 'TAILWIND'],
    href: 'https://kamtridit.cz',
  },
  {
    name: 'Čistou přírodou',
    description:
      'Public nature-trails platform for EKO-KOM. Complete redesign implemented pixel-perfect from a new visual identity: 66 routes with GPX ingestion, per-route difficulty, and interactive map waypoints · Czechia',
    stack: ['REACT', 'TYPESCRIPT', 'MAPLIBRE', 'TAILWIND'],
    href: 'https://prirodou.samosebou.cz',
  },
  {
    name: 'BH-Passport',
    description: 'Travel agency platform, custom Sanity CMS, Lighthouse 97 · Bosnian market',
    stack: ['NEXT.JS', 'SANITY', 'TYPESCRIPT'],
    href: 'https://bhpassport.ba',
  },
  {
    name: 'TableTap',
    description:
      'Restaurant operations platform. Took the AI-generated admin prototype to production, now live in restaurants: multi-branch management, custom analytics, and an AI tool that turns a photographed menu into structured menu items · Codepool in-house product',
    stack: ['SVELTE', 'ASTRO', 'TYPESCRIPT'],
    href: 'https://www.table-tap.app/',
  },
] as const;
---

<section id="work">
  <p class="section-label">Selected work</p>
  <div class="section-body">
    <ul class="work-list">
      {
        projects.map((project) => (
          <ProjectRow
            name={project.name}
            description={project.description}
            stack={project.stack}
            href={project.href}
          />
        ))
      }
    </ul>
  </div>
</section>

<style>
  #work {
    margin-bottom: var(--section-gap);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .section-body {
    padding-top: 32px;
  }

  .work-list {
    list-style: none;
    margin-top: 0;
  }
</style>
