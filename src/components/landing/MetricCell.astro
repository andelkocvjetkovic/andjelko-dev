---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
const labelParts = label.split('\n');
---

<div class="metric">
  <div class="metric-number">{value}</div>
  <div class="metric-label">
    {labelParts.map((part, index) => <>{index > 0 && <br />}{part}</>)}
  </div>
</div>

<style>
  .metric {
    position: relative;
    padding: 32px 24px;
  }

  .metric:first-child {
    padding-left: 0;
  }

  .metric:last-child {
    padding-right: 0;
  }

  .metric::after,
  .metric::before {
    content: '';
    position: absolute;
    background: var(--border);
  }

  .metric::after {
    top: 0;
    right: 0;
    bottom: 0;
    width: 1px;
  }

  .metric::before {
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    display: none;
  }

  .metric:nth-child(4)::after {
    display: none;
  }

  .metric-number {
    font-family: var(--font-body);
    font-size: 42px;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 12px;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .metric {
      padding-right: 20px;
    }

    .metric:nth-child(2n + 1) {
      padding-left: 0;
      padding-right: 20px;
    }

    .metric:nth-child(2n) {
      padding-left: 20px;
      padding-right: 0;
    }

    .metric:nth-child(2n)::after {
      display: none;
    }

    .metric:nth-child(-n + 2)::before {
      display: block;
    }

    .metric:nth-child(4)::after {
      display: none;
    }
  }
</style>
