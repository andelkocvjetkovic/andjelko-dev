---
import { landing } from '../../data/landing';
---

<section id="about">
  <p class="section-label">About</p>
  <div class="section-body">
    {landing.about.map((paragraph) => <p class="about-text">{paragraph}</p>)}
  </div>
</section>

<style>
  #about {
    margin-bottom: var(--section-gap);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .section-body {
    display: grid;
    gap: 16px;
    padding-top: 32px;
  }

  .about-text {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--fg);
    max-width: 620px;
    margin: 0;
  }
</style>
